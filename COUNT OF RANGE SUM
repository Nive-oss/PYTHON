class Solution:
    def countRangeSum(self, nums, lower, upper):
        # Create prefix sums: sums[i] is sum of nums[0...i-1]
        sums = [0]
        for x in nums:
            sums.append(sums[-1] + x)
            
        def count_while_merge_sort(start, end):
            if end - start <= 1:
                return 0
            
            mid = (start + end) // 2
            count = count_while_merge_sort(start, mid) + count_while_merge_sort(mid, end)
            
            # Count the valid ranges crossing the midpoint
            j = k = mid
            for i in range(start, mid):
                # Find the first index j such that sums[j] - sums[i] >= lower
                while j < end and sums[j] - sums[i] < lower:
                    j += 1
                # Find the first index k such that sums[k] - sums[i] > upper
                while k < end and sums[k] - sums[i] <= upper:
                    k += 1
                count += k - j
            
            # Standard merge step to keep prefix sums sorted
            sums[start:end] = sorted(sums[start:end])
            return count

        return count_while_merge_sort(0, len(sums))
