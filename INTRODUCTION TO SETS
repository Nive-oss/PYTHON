def average(array):
    distinct_heights = set(array)
    total_sum = sum(distinct_heights)
    number_of_distinct_heights = len(distinct_heights)
    result = total_sum / number_of_distinct_heights
    return result

if __name__ == '__main__':
    n = int(input())
    arr = list(map(int, input().split()))
    result = average(arr)
    print(result)
