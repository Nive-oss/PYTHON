import heapq

class MedianFinder:
    def __init__(self):
        # max_heap stores the smaller half (negative numbers to simulate max-heap)
        self.small = [] 
        # min_heap stores the larger half
        self.large = [] 

    def addNum(self, num):
        # 1. Push to max-heap, then move the largest of 'small' to 'large'
        heapq.heappush(self.small, -num)
        heapq.heappush(self.large, -heapq.heappop(self.small))
        
        # 2. Maintain balance: 'small' can have at most 1 more element than 'large'
        if len(self.large) > len(self.small):
            heapq.heappush(self.small, -heapq.heappop(self.large))

    def findMedian(self):
        # Check if the total size is odd
        if len(self.small) > len(self.large):
            return float(-self.small[0])
        # Otherwise, size is even; return average of the two middle elements
        return (-self.small[0] + self.large[0]) / 2.0
