class Solution:
    def minPatches(self, nums, n):
        patches = 0
        miss = 1  # The smallest number we cannot form
        i = 0
        
        while miss <= n:
            if i < len(nums) and nums[i] <= miss:
                # We can use the existing number to extend our range
                miss += nums[i]
                i += 1
            else:
                # We must patch the array with 'miss'
                miss += miss
                patches += 1
                
        return patches

