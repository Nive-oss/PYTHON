import sys

# Define a manual GCD function for compatibility with all Python versions
def get_gcd(a, b):
    while b:
        a, b = b, a % b
    return a

def solve():
    # Fast I/O: read all input at once
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    ptr = 0
    t = int(input_data[ptr])
    ptr += 1
    
    results = []
    for _ in range(t):
        n = int(input_data[ptr])
        ptr += 1
        arr = list(map(int, input_data[ptr : ptr + n]))
        ptr += n
        
        # Track the most recent index for each unique value
        last_seen_idx = {}
        ans = []
        
        for i, x in enumerate(arr):
            max_p_idx = -1
            # Only iterate over the unique values seen so far
            for val, idx in last_seen_idx.items():
                if get_gcd(x, val) == 1:
                    if idx > max_p_idx:
                        max_p_idx = idx
            
            ans.append(str(max_p_idx))
            # Update the latest index for the current value
            last_seen_idx[x] = i
            
        results.append(" ".join(ans))
    
    # Print all results at once for speed
    sys.stdout.write("\n".join(results) + "\n")

if __name__ == "__main__":
    solve()
