class Codec:

    def serialize(self, root):
        """Encodes a tree to a single string."""
        res = []
        def dfs(node):
            if not node:
                res.append("N")
                return
            res.append(str(node.val))
            dfs(node.left)
            dfs(node.right)
        
        dfs(root)
        return ",".join(res)

    def deserialize(self, data):
        """Decodes your encoded data to tree."""
        # Split string back into a list of values
        vals = data.split(",")
        self.index = 0
        
        def dfs():
            if vals[self.index] == "N":
                self.index += 1
                return None
            
            # Create the node and move to the next value in the list
            node = TreeNode(int(vals[self.index]))
            self.index += 1
            
            # Recursively build left and right subtrees
            node.left = dfs()
            node.right = dfs()
            return node
        
        return dfs()
